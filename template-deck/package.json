{
  "name": "DECK_NAME_PLACEHOLDER",
  "type": "module",
  "private": true,
  "slidev": {
    "highlighter": "shiki",
    "shiki": {
      "theme": "dark-plus"
    }
  },
  "scripts": {
    "dev": "slidev",
    "build": "slidev build --base /REPO_BASE_PLACEHOLDER/DECK_NAME_PLACEHOLDER/ && cp public/404.html dist/404.html",
    "export": "slidev export",
    "deploy": "npm run build && npx gh-pages -d dist -e DECK_NAME_PLACEHOLDER"
  },
  "dependencies": {
    "@slidev/cli": "^52.9.1",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
